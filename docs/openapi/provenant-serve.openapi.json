              {
                "type": "object",
                "properties": {
                  "path": {
                    "type": "string"
                  },
                  "type": {
                    "type": "string",
                    "const": "directory"
                  }
                },
                "required": [
                  "type",
                  "path"
                ]
              }
            ]
          }
        }
      },
